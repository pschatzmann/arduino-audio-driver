#pragma once
#include "IDriverDeviceInfo.h"
#include <zephyr/device.h>
#include <zephyr/kernel.h>

namespace audio_driver {

/**
 * @brief I2S pins
 * @author Phil Schatzmann
 * @copyright GPLv3
 */
struct InfoI2S {
  InfoI2S() = default;
  InfoI2S(PinFunction function, device* dev_i2s, int port = 0) {
    this->function = function;
    this->dev_i2s = dev_i2s;
    this->port = port;
  }
  PinFunction function;
  device* dev_i2s = nullptr;
  int port = 0;  // port number
};

/**
 * @brief SPI pins: In Arduino we initialize the SPI, on other platform
 * we just provide the pin information
 * @author Phil Schatzmann
 * @copyright GPLv3
 */
struct InfoSPI : public SPIConfig {
  InfoSPI() = default; 

  InfoSPI(PinFunction function, device* dev_spi) {
    this->function = function;
    this->dev_spi = dev_spi;
  }

  PinFunction function;
  device* dev_spi = nullptr; // zephyr device

  bool pinsAvailable() { return dev_spi; }
  operator bool() { return pinsAvailable(); }
  bool begin() { return true; }
  void end() { AD_LOGD("PinsSPI::end"); }
};

/**
 * @brief I2C pins
 * @author Phil Schatzmann
 * @copyright GPLv3
 */
struct InfoI2C : public I2CConfig {
  InfoI2C() {
    port = 0;
    address = -1;
    set_active = true;
    p_wire = nullptr;
  };

  InfoI2C(PinFunction function, device* dev_i2c, int address = -1,

          bool active = true) {
    this->function = function;
    this->dev_i2c = dev_i2c;
    this->set_active = active;
    this->address = address;
  }

  PinFunction function;
  bool set_active = true;
  device* dev_i2c = nullptr;

  bool pinsAvailable() { return dev_i2c != nullptr; }
  operator bool() { return pinsAvailable(); }

  bool begin() {
    if (set_active) {
      return true;
    }
    return true;
  }
  void end() {
    if (set_active){

    } 
  }
};

class IDriverDeviceInfo {
 public:
   virtual audio_driver_local::Optional<InfoI2C> getI2CPins(PinFunction function) = 0;
};

} // namespace audio_driver

